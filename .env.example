# ============================================================
# AI Job Application Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# ============================================================

# ── Required ─────────────────────────────────────────────────
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Auto-generated on first run (do NOT set manually) ────────
# The agent generates this key and appends it to .env on first run.
# ENCRYPTION_KEY=

# ── Optional: override safety limits ─────────────────────────
# MAX_APPS_PER_RUN=20       # Max applications per session (default: 20)
# ACTION_DELAY_MIN=2.0      # Min seconds between browser actions (default: 2.0)
# ACTION_DELAY_MAX=5.0      # Max seconds between browser actions (default: 5.0)
# SKIP_APPLIED_DAYS=90      # Skip if applied to same job within N days (default: 90)

# ── Notes ────────────────────────────────────────────────────
# LinkedIn credentials and application email are stored in passwords.enc
# (encrypted with ENCRYPTION_KEY) during --setup. They are NOT stored here.
#
# Job portal selection is saved to my_documents/search_config.json
# during --setup. It is NOT stored here.
